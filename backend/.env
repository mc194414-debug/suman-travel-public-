# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Credentials
JWT_ACCESS_SECRET=placeholder-super-secret-key-at-least-64-characters-long-suman-travels
JWT_REFRESH_SECRET=placeholder-super-secret-refresh-key-at-least-64-characters-long-suman-travels
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=noreply@sumantravels.com

# Redis Configuration (Upstash)
REDIS_URL=your-redis-url
REDIS_TOKEN=your-redis-token

# Google Maps API
GOOGLE_MAPS_API_KEY=your-maps-key

# Sentry
SENTRY_DSN=your-sentry-dsn
